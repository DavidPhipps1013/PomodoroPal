{
  "name": "Pomodoro Pal",
  "description": "Your favorite studying companion!",
  "version": "0.0",
  "manifest_version": 3,
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "hello.html",
    "default_icon": "images/hello_extensions.png",
    "content_scripts": [
      {
        "matches": [
          "https://www.crunchyroll.com/*"
        ],
        "js": [
          "scripts/content.js"
        ]
      }
    ],
    "web_accessible_resources": [{
      "resources": ["images/overlay.png"],
      "matches": ["<all_urls>"]
    }]
  }
}