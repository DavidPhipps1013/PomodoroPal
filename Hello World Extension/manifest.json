{
  "name": "Pomodoro Pal",
  "description": "Your favorite studying companion!",
  "version": "0.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "hello.html",
    "default_icon": "images/hello_extensions.png"
  },
  "permissions": ["activeTab", "scripting"],
    "content_scripts": [
      {
        "matches": [
          "<all_urls>"
        ],
        "exclude_matches": [
          "https://google.com/*",
          "https://canvas.emich.edu/",
          "https://login.microsoftonline.com/*"
        ],
        "js": [
          "scripts/content.js"
        ]
      },
      {
        "matches": [
          "<all_urls>"
        ],
        "js": [
          "scripts/popup.js"
        ]
      }
    ],
    "web_accessible_resources": [{
      "resources": ["timer.html", "images/*"],
      "matches": ["<all_urls>"]
    }]
  }
